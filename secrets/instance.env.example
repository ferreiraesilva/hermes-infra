# Secret POR CLIENTE. Copiar no host para
# ~/.config/hermes-infra/secrets/<ambiente>/<cliente>.env
#
# 1 token Telegram por profile (a chave é o `telegram_secret` do inventário):
TMHA_LEO_TM_HML_BOT_TOKEN=
TMHA_LEO_MI_HML_BOT_TOKEN=
#
# 1 senha por produto contratado (chave = DB_<PRODUTO>_PASSWORD, onde PRODUTO é
# o db_slug em maiúsculas). Use apenas caracteres URL-safe:
DB_TASKME_PASSWORD=
DB_INCORPORADORA_PASSWORD=
#
# Opcional, restrição de remetentes:
# TELEGRAM_ALLOWED_USERS=
