+    def approve_user(self, platform: str, user_id: str, user_name: str = "") -> None:
+        """Approve a known platform user ID without issuing a pairing code."""
+        normalized_platform = str(platform or "").lower().strip()
+        normalized_user_id = self._normalize_user_id(normalized_platform, user_id)
+        if not normalized_platform or not normalized_user_id:
+            raise ValueError("platform and user_id are required")
+        with self._lock:
+            self._approve_user(normalized_platform, normalized_user_id, user_name)
+
     def revoke(self, platform: str, user_id: str) -> bool:
         """Remove a user from the approved list. Returns True if found."""
         path = self._approved_path(platform)
