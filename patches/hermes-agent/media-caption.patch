+#   MEDIA_CAPTION:{"path":"/tmp/planta.jpg","caption":"Planta do 2 quartos.","type":"image"}
+MEDIA_CAPTION_RE = re.compile(
+    r'^[ \t]*MEDIA_CAPTION:\s*'
+    r'(?P<payload>\{(?=[^\n]*"type"\s*:\s*"(?:video|image)")[^\n]*\})[ \t]*$',
+    re.MULTILINE,
