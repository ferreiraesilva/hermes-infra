+# Structured directive used only for native video captions. Image delivery
+# remains on the existing markdown-image path until it is migrated separately.
+# Example:
+#   MEDIA_CAPTION:{"path":"/tmp/tour.mp4","caption":"Tour do decorado.","type":"video"}
+MEDIA_CAPTION_RE = re.compile(
+    r'^[ \t]*MEDIA_CAPTION:\s*'
+    r'(?P<payload>\{(?=[^\n]*"type"\s*:\s*"video")[^\n]*\})[ \t]*$',
+    re.MULTILINE,
+)
